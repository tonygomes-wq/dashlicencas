# Ambiente
NODE_ENV=development

# Servidor
PORT=3001
API_PREFIX=/api/v1

# Banco de Dados
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=dashlicencas

# JWT
JWT_SECRET=seu_secret_super_seguro_aqui_mude_em_producao
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CRON (para sincronização automática)
CRON_SECRET_TOKEN=seu_token_secreto_aqui_123456

# CORS (separar múltiplas origens com vírgula)
CORS_ORIGIN=http://localhost:5173,https://dashlicencas.macip.com.br

# Bitdefender
BITDEFENDER_DEFAULT_URL=https://cloud.gravityzone.bitdefender.com/api

# Logs
LOG_LEVEL=info
